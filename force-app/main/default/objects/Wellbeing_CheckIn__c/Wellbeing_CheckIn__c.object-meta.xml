<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Captures burnout/strain signals observed in conversation and the guardrail escalation outcome. Non-clinical.</description>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <label>Wellbeing Check-In</label>
    <nameField>
        <displayFormat>WB-{00000}</displayFormat>
        <label>Check-In Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Wellbeing Check-Ins</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
